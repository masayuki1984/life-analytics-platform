# ==============================================================
# .env.example — 環境変数のテンプレート
#
# このファイルを .env にコピーして実際の値を記入してください。
#   cp .env.example .env
#
# .env は git にコミットしません。
# .env.example は git にコミットします（機密情報は書かない）。
# ==============================================================

# --------------------------------------------------------------
# アプリケーション設定
# --------------------------------------------------------------
APP_ENV=development         # development | staging | production
APP_PORT=8000
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# --------------------------------------------------------------
# Obsidian / Plaud インポーター設定
# --------------------------------------------------------------
# Obsidian Vault の絶対パス（必須）
OBSIDIAN_VAULT_PATH=/Users/yourname/SecondBrain

# Plaud CLI コマンド（任意 — デフォルト: npx @plaud-ai/cli）
# PLAUD_CLI=npx @plaud-ai/cli

# --------------------------------------------------------------
# 外部 API キー
# （実際のキーは絶対にここに書かない。.env にのみ記入する）
# --------------------------------------------------------------
# ex（取引所）:
# BITBANK_API_KEY=your_api_key_here
# BITBANK_API_SECRET=your_api_secret_here
#
# ex（クラウドサービス）:
# OPENAI_API_KEY=your_api_key_here
# STRIPE_SECRET_KEY=your_secret_key_here

{SERVICE_NAME}_API_KEY=your_api_key_here
{SERVICE_NAME}_API_SECRET=your_api_secret_here

# --------------------------------------------------------------
# ストレージ / データベース
# --------------------------------------------------------------
# ex（AWS S3）:
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION=ap-northeast-1
# S3_BUCKET_NAME=your-bucket-name

# ex（Cloudflare R2）:
# R2_ACCESS_KEY_ID=your_access_key_here
# R2_SECRET_ACCESS_KEY=your_secret_key_here
# R2_ENDPOINT_URL=https://{account_id}.r2.cloudflarestorage.com
# R2_BUCKET_NAME=your-bucket-name

# ex（PostgreSQL）:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ex（Redis）:
# REDIS_URL=redis://localhost:6379/0

{STORAGE_KEY}=your_value_here

# --------------------------------------------------------------
# 通知
# --------------------------------------------------------------
# ex（Discord）:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ex（Slack）:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# {NOTIFICATION_WEBHOOK_URL}=your_webhook_url_here
